# Sao chép file này thành ".env.local" rồi điền giá trị thật.
# KHÔNG commit .env.local lên Git.

# --- Supabase (lấy ở Supabase > Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...        # public anon key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...            # chỉ dùng phía server, BÍ MẬT

# --- Microsoft 365 / Azure AD (cho SSO + Teams, dùng ở bước sau) ---
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
